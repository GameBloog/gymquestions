# Application
NODE_ENV=development
PORT=3333
TRUST_PROXY=false

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/api_gym?schema=public"

# JWT
JWT_SECRET=troque-esta-chave-jwt-por-uma-sequencia-segura-com-mais-de-64-caracteres-unicos
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_DAYS=30

# Security
BCRYPT_ROUNDS=10
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_TIMEWINDOW=60000
# CORS_ORIGIN=https://seu-frontend.example.com

# Cloudinary (para upload de arquivos)
CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=sua_api_key
CLOUDINARY_API_SECRET=seu_api_secret

# File Upload Limits
MAX_FILE_SIZE=5242880
MAX_PHOTO_SIZE=2097152

# Notifications Scheduler
ENABLE_NOTIFICATION_SCHEDULER=false
NOTIFICATION_TIMEZONE=America/Sao_Paulo
FRIDAY_PHOTO_REMINDER_CRON=0 9 * * 5
REAVALIACAO_REMINDER_CRON=0 8 * * *

# SMTP (email)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=dev@gforce.local
SMTP_FROM_NAME=G-Force

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# External Exercise API
EXERCISE_API_BASE_URL=https://wger.de/api/v2

# External Food APIs
USDA_API_BASE_URL=https://api.nal.usda.gov/fdc/v1
USDA_API_KEY=
# Descomente se voce estiver rodando o TACO GraphQL localmente.
# TACO_API_BASE_URL=http://localhost:4000/graphql
TACO_API_KEY=
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_HANDLE=gforce.oficialbr
YOUTUBE_LATEST_CACHE_TTL_SECONDS=86400

# Lead Tracking
LEAD_TRACKING_SALT=troque-este-salt-por-uma-sequencia-segura-com-pelo-menos-16-caracteres
