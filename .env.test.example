# Application
NODE_ENV=test
PORT=3334

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5434/api_gym_test?schema=public"

# JWT
JWT_SECRET=test_secret_key_for_testing_purposes_with_64_characters_minimum_1234
JWT_EXPIRES_IN=1d

# Security
BCRYPT_ROUNDS=10

# Cloudinary (placeholders validos para o parser de env)
CLOUDINARY_CLOUD_NAME=test-cloud
CLOUDINARY_API_KEY=test-key
CLOUDINARY_API_SECRET=test-secret

# File Upload Limits
MAX_FILE_SIZE=5242880
MAX_PHOTO_SIZE=2097152

# Notifications Scheduler
ENABLE_NOTIFICATION_SCHEDULER=false
NOTIFICATION_TIMEZONE=America/Sao_Paulo
FRIDAY_PHOTO_REMINDER_CRON=0 9 * * 5
REAVALIACAO_REMINDER_CRON=0 8 * * *

# SMTP (email)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=test@gforce.local
SMTP_FROM_NAME=G-Force

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# External APIs
EXERCISE_API_BASE_URL=https://wger.de/api/v2
USDA_API_BASE_URL=https://api.nal.usda.gov/fdc/v1
USDA_API_KEY=
# Descomente se um ambiente de teste precisar do TACO GraphQL local.
# TACO_API_BASE_URL=http://localhost:4000/graphql
TACO_API_KEY=
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_HANDLE=gforce.oficialbr
YOUTUBE_LATEST_CACHE_TTL_SECONDS=86400

# Lead Tracking
LEAD_TRACKING_SALT=test-lead-tracking-salt-1234
